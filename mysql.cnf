[mysqld]
# Default Storage Engine
default-storage-engine = InnoDB

# Character Set Configuration
character-set-server = utf8mb4
collation-server = utf8mb4_unicode_ci

# Connection Settings
max_connections = 1000
max_allowed_packet = 64M
connect_timeout = 10
wait_timeout = 28800
max_idle_connections = 100

# Performance Tuning
innodb_buffer_pool_size = 256M
innodb_log_file_size = 100M
innodb_flush_log_at_trx_commit = 2
innodb_flush_method = O_DIRECT

# Slow Query Log
slow_query_log = 1
slow_query_log_file = /var/log/mysql/slow-query.log
long_query_time = 2

# Binary Logging (for replication/backup)
log_bin = /var/log/mysql/mysql-bin.log
binlog_format = mixed
expire_logs_days = 10

# Server ID (important for replication)
server-id = 1

# Skip name resolution
skip-external-locking
skip-name-resolve

# Logging
log_error = /var/log/mysql/error.log

# Query Cache (deprecated in MySQL 8.0, but keeping for compatibility)
# query_cache_size = 0
# query_cache_type = 0

# For large Moodle installations
max_sort_length = 4096

# Database size limits
innodb_file_per_table = 1

# Authentication Plugin (MySQL 8.0)
default_authentication_plugin = mysql_native_password

[mysqldump]
quick
quote-names
max_allowed_packet = 64M

[mysql]
# No database specified

[mysqld_safe]
log-error = /var/log/mysql/error.log
pid-file = /var/run/mysqld/mysqld.pid
